# SMTP (Gmail App Password)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Google OAuth2 (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT Secret (min 256 bits for HS256)
JWT_SECRET=YourSecretKeyThatIsAtLeast256BitsLongForHS256Algorithm!

# PostgreSQL Database (Neon / Supabase / local)
DATABASE_URL=jdbc:postgresql://your-host/your-db?sslmode=require
DATABASE_DRIVER=org.postgresql.Driver
DATABASE_USERNAME=your-db-username
DATABASE_PASSWORD=your-db-password

# Deployment (set these on your hosting platform)
CORS_ORIGINS=https://your-frontend-domain.com
FRONTEND_URL=https://your-frontend-domain.com
PORT=8080

# Google Gemini AI (optional)
GEMINI_API_KEY=
